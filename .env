# ==================== EMAILJS CONFIGURATION ====================
# Get these from https://www.emailjs.com/
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here
REACT_APP_EMAILJS_SERVICE_ID=service_xxxxx
REACT_APP_EMAILJS_PRAYER_TEMPLATE=template_xxxxx
REACT_APP_EMAILJS_CONTACT_TEMPLATE=template_xxxxx
REACT_APP_EMAILJS_EVENT_TEMPLATE=template_xxxxx
REACT_APP_EMAILJS_NEWSLETTER_TEMPLATE=template_xxxxx

# ==================== PAYMENT GATEWAY ====================
# Get from https://dashboard.paystack.com/
REACT_APP_PAYSTACK_PUBLIC_KEY=pk_live_xxxxx

# ==================== ANALYTICS ====================
# Google Analytics (UA-XXXXX-Y or G-XXXXXXXXXX)
REACT_APP_GA_ID=UA-xxxxx
# Facebook Pixel (optional - leave empty if not using)
REACT_APP_FB_PIXEL_ID=

# ==================== BACKEND API ====================
# Change to your production URL when deploying
REACT_APP_API_URL=http://localhost:5000/api

# ==================== DEVELOPMENT SETTINGS ====================
# Set to true to see analytics logs in console
REACT_APP_ANALYTICS_DEBUG=false

# React development settings
FAST_REFRESH=true
GENERATE_SOURCEMAP=false
BROWSER=none